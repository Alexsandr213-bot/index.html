<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShadowLink VPN</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
        }
        
        body {
            background: linear-gradient(135deg, #0a0a1a, #1a1a3a);
            color: var(--tg-theme-text-color, #fff);
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }
        
        /* Анимированный фон с эмодзи */
        .emoji-background {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
            overflow: hidden;
        }
        
        .floating-emoji {
            position: absolute;
            font-size: 24px;
            opacity: 0.15;
            animation: float 20s linear infinite;
            filter: drop-shadow(0 0 10px rgba(0, 212, 255, 0.3));
            user-select: none;
            white-space: nowrap;
        }
        
        .floating-emoji:nth-child(1) { top: 10%; left: 5%; animation-duration: 25s; font-size: 32px; }
        .floating-emoji:nth-child(2) { top: 20%; left: 15%; animation-duration: 18s; font-size: 28px; animation-delay: -2s; }
        .floating-emoji:nth-child(3) { top: 30%; left: 85%; animation-duration: 22s; font-size: 36px; animation-delay: -5s; }
        .floating-emoji:nth-child(4) { top: 40%; left: 45%; animation-duration: 30s; font-size: 40px; animation-delay: -8s; }
        .floating-emoji:nth-child(5) { top: 50%; left: 75%; animation-duration: 15s; font-size: 26px; animation-delay: -3s; }
        .floating-emoji:nth-child(6) { top: 60%; left: 25%; animation-duration: 28s; font-size: 34px; animation-delay: -12s; }
        .floating-emoji:nth-child(7) { top: 70%; left: 55%; animation-duration: 20s; font-size: 30px; animation-delay: -7s; }
        .floating-emoji:nth-child(8) { top: 80%; left: 35%; animation-duration: 24s; font-size: 38px; animation-delay: -15s; }
        .floating-emoji:nth-child(9) { top: 15%; left: 95%; animation-duration: 26s; font-size: 42px; animation-delay: -10s; }
        .floating-emoji:nth-child(10) { top: 85%; left: 65%; animation-duration: 19s; font-size: 29px; animation-delay: -4s; }
        .floating-emoji:nth-child(11) { top: 45%; left: 8%; animation-duration: 23s; font-size: 33px; animation-delay: -9s; }
        .floating-emoji:nth-child(12) { top: 25%; left: 72%; animation-duration: 27s; font-size: 37px; animation-delay: -14s; }
        .floating-emoji:nth-child(13) { top: 65%; left: 88%; animation-duration: 21s; font-size: 31px; animation-delay: -6s; }
        .floating-emoji:nth-child(14) { top: 75%; left: 12%; animation-duration: 29s; font-size: 35px; animation-delay: -11s; }
        .floating-emoji:nth-child(15) { top: 35%; left: 92%; animation-duration: 17s; font-size: 27px; animation-delay: -13s; }
        
        /* Вторая волна эмодзи (двигаются в другом направлении) */
        .floating-emoji-second {
            position: absolute;
            font-size: 20px;
            opacity: 0.1;
            animation: floatReverse 25s linear infinite;
            filter: drop-shadow(0 0 15px rgba(123, 44, 191, 0.3));
            user-select: none;
        }
        
        .floating-emoji-second:nth-child(16) { top: 5%; left: 20%; animation-duration: 24s; font-size: 26px; }
        .floating-emoji-second:nth-child(17) { top: 55%; left: 40%; animation-duration: 19s; font-size: 22px; animation-delay: -3s; }
        .floating-emoji-second:nth-child(18) { top: 95%; left: 60%; animation-duration: 28s; font-size: 30px; animation-delay: -7s; }
        .floating-emoji-second:nth-child(19) { top: 18%; left: 80%; animation-duration: 22s; font-size: 24px; animation-delay: -12s; }
        .floating-emoji-second:nth-child(20) { top: 72%; left: 95%; animation-duration: 26s; font-size: 28px; animation-delay: -5s; }
        .floating-emoji-second:nth-child(21) { top: 88%; left: 28%; animation-duration: 20s; font-size: 21px; animation-delay: -9s; }
        .floating-emoji-second:nth-child(22) { top: 42%; left: 52%; animation-duration: 29s; font-size: 32px; animation-delay: -15s; }
        .floating-emoji-second:nth-child(23) { top: 12%; left: 68%; animation-duration: 18s; font-size: 23px; animation-delay: -2s; }
        .floating-emoji-second:nth-child(24) { top: 62%; left: 15%; animation-duration: 27s; font-size: 29px; animation-delay: -8s; }
        .floating-emoji-second:nth-child(25) { top: 48%; left: 82%; animation-duration: 23s; font-size: 25px; animation-delay: -11s; }
        
        @keyframes float {
            0% {
                transform: translateY(0) translateX(0) rotate(0deg);
                opacity: 0.1;
            }
            25% {
                transform: translateY(-20px) translateX(10px) rotate(5deg);
                opacity: 0.2;
            }
            50% {
                transform: translateY(20px) translateX(-10px) rotate(-5deg);
                opacity: 0.15;
            }
            75% {
                transform: translateY(-10px) translateX(20px) rotate(3deg);
                opacity: 0.2;
            }
            100% {
                transform: translateY(0) translateX(0) rotate(0deg);
                opacity: 0.1;
            }
        }
        
        @keyframes floatReverse {
            0% {
                transform: translateY(0) translateX(0) rotate(0deg);
                opacity: 0.08;
            }
            25% {
                transform: translateY(20px) translateX(-15px) rotate(-3deg);
                opacity: 0.15;
            }
            50% {
                transform: translateY(-15px) translateX(15px) rotate(4deg);
                opacity: 0.1;
            }
            75% {
                transform: translateY(15px) translateX(-10px) rotate(-2deg);
                opacity: 0.15;
            }
            100% {
                transform: translateY(0) translateX(0) rotate(0deg);
                opacity: 0.08;
            }
        }
        
        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 16px;
            position: relative;
            z-index: 1;
        }
        
        .header {
            text-align: center;
            margin-bottom: 24px;
            padding: 20px;
            background: rgba(22, 33, 62, 0.8);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(0, 212, 255, 0.2);
            border: 1px solid rgba(0, 212, 255, 0.3);
        }
        
        .header h1 {
            font-size: 32px;
            margin-bottom: 8px;
            background: linear-gradient(45deg, #00d4ff, #7b2cbf, #ff00aa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 20px rgba(0, 212, 255, 0.5);
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 24px;
        }
        
        .stat-card {
            background: rgba(22, 33, 62, 0.7);
            backdrop-filter: blur(5px);
            -webkit-backdrop-filter: blur(5px);
            padding: 16px;
            border-radius: 16px;
            text-align: center;
            border: 1px solid rgba(0, 212, 255, 0.3);
            transition: transform 0.3s, box-shadow 0.3s;
        }
        
        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 212, 255, 0.3);
        }
        
        .stat-value {
            font-size: 24px;
            font-weight: bold;
            color: #00d4ff;
            margin-bottom: 4px;
            text-shadow: 0 0 10px rgba(0, 212, 255, 0.5);
        }
        
        .stat-label {
            font-size: 14px;
            opacity: 0.8;
        }
        
        .ping-indicator {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: 6px;
            animation: pulse 1.5s infinite;
        }
        
        .ping-low {
            background: #00ff00;
            box-shadow: 0 0 15px #00ff00;
        }
        
        .ping-medium {
            background: #ffff00;
            box-shadow: 0 0 15px #ffff00;
        }
        
        .ping-high {
            background: #ff4444;
            box-shadow: 0 0 15px #ff4444;
        }
        
        .server-list {
            background: rgba(22, 33, 62, 0.7);
            backdrop-filter: blur(5px);
            -webkit-backdrop-filter: blur(5px);
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 20px;
            border: 1px solid rgba(0, 212, 255, 0.3);
        }
        
        .server-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 16px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
        }
        
        .server-item:hover {
            background: rgba(0, 212, 255, 0.2);
            transform: scale(1.02);
        }
        
        .server-item:last-child {
            border-bottom: none;
        }
        
        .server-item.premium-server {
            background: linear-gradient(90deg, rgba(255,215,0,0.15), transparent);
            border-left: 3px solid gold;
        }
        
        .server-item.free-server {
            background: linear-gradient(90deg, rgba(100,100,100,0.15), transparent);
            border-left: 3px solid #666;
        }
        
        .server-item.premium-server::after {
            content: "⭐ PREMIUM";
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 10px;
            color: gold;
            font-weight: bold;
            background: rgba(0,0,0,0.5);
            padding: 2px 6px;
            border-radius: 10px;
            backdrop-filter: blur(2px);
        }
        
        .server-info {
            display: flex;
            align-items: center;
            gap: 12px;
            flex: 1;
        }
        
        .server-flag {
            font-size: 28px;
            filter: drop-shadow(0 0 5px rgba(255,255,255,0.3));
        }
        
        .server-name {
            font-weight: 500;
        }
        
        .server-details {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        
        .server-ping {
            font-size: 16px;
            font-weight: bold;
        }
        
        .ping-low-text {
            color: #00ff00;
            text-shadow: 0 0 10px #00ff00;
        }
        
        .ping-medium-text {
            color: #ffff00;
            text-shadow: 0 0 10px #ffff00;
        }
        
        .ping-high-text {
            color: #ff4444;
            text-shadow: 0 0 10px #ff4444;
        }
        
        .load-bar {
            width: 60px;
            height: 4px;
            background: rgba(255,255,255,0.1);
            border-radius: 2px;
            overflow: hidden;
            margin-top: 4px;
        }
        
        .load-fill {
            height: 100%;
            background: linear-gradient(90deg, #00d4ff, #7b2cbf, #ff00aa);
            border-radius: 2px;
            animation: shimmer 2s infinite;
        }
        
        @keyframes shimmer {
            0% { opacity: 0.8; }
            50% { opacity: 1; }
            100% { opacity: 0.8; }
        }
        
        .speed-test {
            background: rgba(22, 33, 62, 0.7);
            backdrop-filter: blur(5px);
            -webkit-backdrop-filter: blur(5px);
            padding: 20px;
            border-radius: 16px;
            margin: 20px 0;
            border: 1px solid rgba(0, 212, 255, 0.3);
        }
        
        .speed-meter {
            height: 8px;
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
            margin: 16px 0;
            overflow: hidden;
        }
        
        .speed-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #00d4ff, #7b2cbf, #ff00aa);
            border-radius: 4px;
            transition: width 0.3s;
            box-shadow: 0 0 20px #00d4ff;
        }
        
        .speed-value {
            text-align: center;
            font-size: 36px;
            font-weight: bold;
            color: #00d4ff;
            margin: 8px 0;
            text-shadow: 0 0 20px #00d4ff;
        }
        
        .features-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin: 20px 0;
        }
        
        .feature-item {
            background: rgba(22, 33, 62, 0.7);
            backdrop-filter: blur(5px);
            -webkit-backdrop-filter: blur(5px);
            padding: 16px;
            border-radius: 16px;
            text-align: center;
            font-size: 14px;
            border: 1px solid rgba(0, 212, 255, 0.3);
            transition: all 0.3s;
        }
        
        .feature-item:hover {
            transform: scale(1.05);
            box-shadow: 0 0 30px rgba(0, 212, 255, 0.3);
        }
        
        .feature-icon {
            font-size: 32px;
            margin-bottom: 8px;
            filter: drop-shadow(0 0 10px #00d4ff);
        }
        
        .tabs {
            display: flex;
            gap: 8px;
            margin: 20px 0;
            overflow-x: auto;
            padding-bottom: 8px;
        }
        
        .tab {
            padding: 10px 20px;
            background: rgba(22, 33, 62, 0.7);
            backdrop-filter: blur(5px);
            -webkit-backdrop-filter: blur(5px);
            border-radius: 20px;
            white-space: nowrap;
            cursor: pointer;
            transition: all 0.3s;
            border: 1px solid rgba(0, 212, 255, 0.3);
        }
        
        .tab:hover {
            background: rgba(0, 212, 255, 0.2);
            transform: translateY(-2px);
        }
        
        .tab.active {
            background: linear-gradient(45deg, #00d4ff, #7b2cbf);
            color: white;
            border: none;
            box-shadow: 0 0 20px #00d4ff;
        }
        
        .tab.premium-tab {
            border: 1px solid gold;
        }
        
        .hidden {
            display: none;
        }
        
        .premium-badge {
            display: inline-block;
            background: linear-gradient(45deg, gold, #ffd700);
            color: #1a1a2e;
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 10px;
            font-weight: bold;
            margin-left: 8px;
            box-shadow: 0 0 10px gold;
        }
        
        .free-badge {
            display: inline-block;
            background: #666;
            color: white;
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 10px;
            margin-left: 8px;
        }
        
        .subscription-status {
            background: linear-gradient(45deg, #00d4ff, #7b2cbf);
            color: white;
            padding: 16px;
            border-radius: 16px;
            text-align: center;
            margin-bottom: 16px;
            font-weight: bold;
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255,255,255,0.2);
            box-shadow: 0 0 30px rgba(0, 212, 255, 0.3);
        }
        
        .ping-legend {
            display: flex;
            gap: 16px;
            justify-content: center;
            margin: 16px 0;
            font-size: 12px;
            background: rgba(22, 33, 62, 0.5);
            backdrop-filter: blur(5px);
            padding: 10px;
            border-radius: 20px;
        }
        
        .legend-item {
            display: flex;
            align-items: center;
            gap: 4px;
        }
        
        .btn {
            padding: 16px;
            border: none;
            border-radius: 16px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            backdrop-filter: blur(5px);
        }
        
        .btn:active {
            transform: scale(0.95);
        }
        
        .btn-primary {
            background: linear-gradient(45deg, #00d4ff, #7b2cbf);
            color: white;
            width: 100%;
            box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
        }
        
        .btn-primary:hover {
            box-shadow: 0 0 30px #00d4ff;
            transform: translateY(-2px);
        }
        
        .btn-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }
        
        .btn-premium {
            background: linear-gradient(45deg, gold, #ffd700);
            color: #1a1a2e;
            font-weight: bold;
            box-shadow: 0 0 20px gold;
        }
        
        .btn-premium:hover {
            box-shadow: 0 0 30px gold;
            transform: translateY(-2px);
        }
        
        .btn-secondary {
            background: rgba(22, 33, 62, 0.7);
            color: var(--tg-theme-text-color, #fff);
            border: 1px solid #00d4ff;
        }
        
        .action-buttons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin: 24px 0;
        }
        
        @keyframes pulse {
            0% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.8; transform: scale(1.1); }
            100% { opacity: 1; transform: scale(1); }
        }

        .toast {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0, 212, 255, 0.9);
            backdrop-filter: blur(10px);
            color: white;
            padding: 12px 24px;
            border-radius: 30px;
            font-weight: 600;
            box-shadow: 0 4px 30px rgba(0, 212, 255, 0.3);
            z-index: 1000;
            animation: slideUp 0.3s ease;
            border: 1px solid rgba(255,255,255,0.2);
        }

        .toast.premium {
            background: rgba(255, 215, 0, 0.9);
            color: #1a1a2e;
        }

        .toast.error {
            background: rgba(255, 68, 68, 0.9);
            color: white;
        }

        .toast.free {
            background: rgba(102, 102, 102, 0.9);
            color: white;
        }

        @keyframes slideUp {
            from {
                transform: translateX(-50%) translateY(100px);
                opacity: 0;
            }
            to {
                transform: translateX(-50%) translateY(0);
                opacity: 1;
            }
        }

        /* Стилизация скроллбара */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        
        ::-webkit-scrollbar-track {
            background: rgba(22, 33, 62, 0.5);
            border-radius: 10px;
        }
        
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(45deg, #00d4ff, #7b2cbf);
            border-radius: 10px;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(45deg, #7b2cbf, #00d4ff);
        }
    </style>
</head>
