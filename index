            <p style="opacity: 0.9; text-shadow: 0 0 10px #00d4ff;">Premium VPN • Обход блокировок</p>
        </div>
        
        <!-- Статус подписки -->
        <div id="subscriptionBanner" class="subscription-status">
            ⚡ Бесплатный режим • Высокий пинг
        </div>
        
        <!-- Легенда пинга -->
        <div class="ping-legend">
            <div class="legend-item">
                <span class="ping-indicator ping-low"></span>
                <span>Низкий пинг (Premium)</span>
            </div>
            <div class="legend-item">
                <span class="ping-indicator ping-medium"></span>
                <span>Средний пинг</span>
            </div>
            <div class="legend-item">
                <span class="ping-indicator ping-high"></span>
                <span>Высокий пинг (Бесплатно)</span>
            </div>
        </div>
        
        <!-- Статистика -->
        <div class="stats-grid" id="stats">
            <div class="stat-card">
                <div class="stat-value" id="onlineUsers">2,847</div>
                <div class="stat-label">Онлайн</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" id="serversCount">94</div>
                <div class="stat-label">Серверов</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" id="countriesCount">51</div>
                <div class="stat-label">Стран</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" id="avgPing">85</div>
                <div class="stat-label">Ср. пинг (мс)</div>
            </div>
        </div>
        
        <!-- Вкладки -->
        <div class="tabs">
            <div class="tab active" onclick="switchTab('servers')">🖥 Серверы</div>
            <div class="tab" onclick="switchTab('speed')">⚡ Speed Test</div>
            <div class="tab" onclick="switchTab('features')">✨ Функции</div>
            <div class="tab" onclick="switchTab('account')">👤 Аккаунт</div>
        </div>
        
        <!-- Вкладка Серверы -->
        <div id="serversTab" class="tab-content">
            <div class="server-list" id="serverList"></div>
            
            <div style="margin-top: 16px; padding: 16px; background: rgba(255,215,0,0.1); backdrop-filter: blur(5px); border-radius: 16px; text-align: center; border: 1px solid gold;">
                <p style="color: gold; margin-bottom: 8px; text-shadow: 0 0 10px gold;">⭐ Premium серверы с низким пингом</p>
                <p style="font-size: 12px; opacity: 0.9;">Бесплатные серверы имеют высокий пинг (красный индикатор)</p>
            </div>
        </div>
        
        <!-- Вкладка Speed Test -->
        <div id="speedTab" class="tab-content hidden">
            <div class="speed-test">
                <h3 style="margin-bottom: 16px; text-shadow: 0 0 10px #00d4ff;">📊 Тест скорости</h3>
                <div class="speed-value" id="speedDisplay">0</div>
                <div class="speed-meter">
                    <div class="speed-fill" id="speedMeter"></div>
                </div>
                <div style="display: flex; justify-content: space-between; margin: 8px 0;">
                    <span>Пинг: <span id="pingDisplay">0</span> мс</span>
                    <span>Потеря: <span id="lossDisplay">0</span>%</span>
                </div>
                <button class="btn btn-primary" onclick="startSpeedTest()" style="margin-top: 16px;" id="speedTestBtn">
                    ▶ Начать тест
                </button>
            </div>
            
            <div class="server-list" style="margin-top: 20px;">
                <div class="server-item free-server" onclick="connectToServer('ru-msk-free')">
                    <div class="server-info">
                        <span class="server-flag">🇷🇺</span>
                        <div class="server-details">
                            <span class="server-name">Москва (Бесплатно)</span>
                            <span class="server-ping ping-high-text">⚠️ 150-200 мс</span>
                        </div>
                    </div>
                    <span class="free-badge">FREE</span>
                </div>
                <div class="server-item free-server" onclick="connectToServer('ru-spb-free')">
                    <div class="server-info">
                        <span class="server-flag">🇷🇺</span>
                        <div class="server-details">
                            <span class="server-name">СПб (Бесплатно)</span>
                            <span class="server-ping ping-high-text">⚠️ 180-230 мс</span>
                        </div>
                    </div>
                    <span class="free-badge">FREE</span>
                </div>
                <div class="server-item premium-server" onclick="connectToServer('de-fra-42')">
                    <div class="server-info">
                        <span class="server-flag">🇩🇪</span>
                        <div class="server-details">
                            <span class="server-name">Франкфурт (Premium)</span>
                            <span class="server-ping ping-low-text">⚡ 15-25 мс</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Вкладка Функции -->
        <div id="featuresTab" class="tab-content hidden">
            <div class="features-grid">
                <div class="feature-item">
                    <div class="feature-icon">🛡️</div>
                    <div>Обход DPI</div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">⚡</div>
                    <div>Низкий пинг</div>
                    <span class="premium-badge">PREMIUM</span>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">🔒</div>
                    <div>No Logs</div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">📱</div>
                    <div>Multi-platform</div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">🌐</div>
                    <div>51 страна</div>
                    <span class="premium-badge">PREMIUM</span>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">🔄</div>
                    <div>Unlimited</div>
                </div>
            </div>
            
            <button class="btn btn-premium" onclick="buySubscription()" style="margin-top: 16px; width: 100%;">
                💎 Получить низкий пинг за 100 ⭐
            </button>
        </div>
        
        <!-- Вкладка Аккаунт -->
        <div id="accountTab" class="tab-content hidden">
            <div class="server-list">
                <div class="server-item">
                    <div class="server-info">
                        <span class="server-flag">👤</span>
                        <span class="server-name">ID пользователя</span>
                    </div>
                    <span id="userId">-</span>
                </div>
                <div class="server-item">
                    <div class="server-info">
                        <span class="server-flag">📅</span>
                        <span class="server-name">Статус</span>
                    </div>
                    <span id="subscriptionStatus">Бесплатный</span>
                </div>
                <div class="server-item">
                    <div class="server-info">
                        <span class="server-flag">📊</span>
                        <span class="server-name">Текущий пинг</span>
                    </div>
                    <span id="currentPing">Высокий</span>
                </div>
                <div class="server-item">
                    <div class="server-info">
                        <span class="server-flag">⚡</span>
                        <span class="server-name">Доступ к низкому пингу</span>
                    </div>
                    <span id="lowPingAccess">❌ Нет</span>
                </div>
            </div>
            
            <div class="action-buttons">
                <button class="btn btn-primary" onclick="getConfig()">⚙️ Получить конфиг</button>
                <button class="btn btn-secondary" onclick="support()">📞 Поддержка</button>
            </div>
        </div>
    </div>
    
    <script>
        const tg = window.Telegram.WebApp;
        tg.expand();
        tg.enableClosingConfirmation();
        
        let userData = {};
        let servers = [];
        let speedTestInterval;
        let hasPremium = false;
        
        // Инициализация
        tg.ready();
        userData = tg.initDataUnsafe?.user || {};
        document.getElementById('userId').textContent = userData.id || 'Неизвестно';
        
        function checkPremiumStatus() {
            tg.sendData(JSON.stringify({
                action: 'check_premium'
            }));
        }
        
        function showToast(message, type = 'info') {
            const toast = document.createElement('div');
            toast.className = 'toast';
            if (type === 'premium') toast.classList.add('premium');
            if (type === 'error') toast.classList.add('error');
            if (type === 'free') toast.classList.add('free');
            toast.textContent = message;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.remove();
            }, 3000);
        }
        
        function updateUIForPremium() {
            const banner = document.getElementById('subscriptionBanner');
            const subscriptionStatus = document.getElementById('subscriptionStatus');
            const lowPingAccess = document.getElementById('lowPingAccess');
            const currentPing = document.getElementById('currentPing');
            const avgPing = document.getElementById('avgPing');
            
            if (hasPremium) {
                banner.innerHTML = '✨ Premium активен • Доступны серверы с низким пингом ✨';
                banner.style.background = 'linear-gradient(45deg, gold, #ffd700)';
                banner.style.color = '#1a1a2e';
                subscriptionStatus.textContent = 'Premium';
                subscriptionStatus.style.color = 'gold';
                subscriptionStatus.style.fontWeight = 'bold';
                lowPingAccess.innerHTML = '✅ Да';
                lowPingAccess.style.color = '#00ff00';
                currentPing.textContent = 'Низкий';
                currentPing.style.color = '#00ff00';
                avgPing.textContent = '32';
            } else {
                banner.innerHTML = '⚡ Бесплатный режим • Доступны только серверы с высоким пингом ⚡';
                banner.style.background = 'linear-gradient(45deg, #666, #444)';
                banner.style.color = 'white';
                subscriptionStatus.textContent = 'Бесплатный';
                subscriptionStatus.style.color = '';
                subscriptionStatus.style.fontWeight = '';
                lowPingAccess.innerHTML = '❌ Нет';
                lowPingAccess.style.color = '#ff4444';
                currentPing.textContent = 'Высокий';
                currentPing.style.color = '#ff4444';
                avgPing.textContent = '85';
            }
            
            loadServers();
        }
        
        function loadServers() {
            servers = [
                // Premium серверы - низкий пинг
                { flag: '🇩🇪', country: 'Германия', city: 'Франкфурт', ping: 15, pingRange: '15-25', load: 43, code: 'de-fra-42', premium: true, pingLevel: 'low' },
                { flag: '🇳🇱', country: 'Нидерланды', city: 'Амстердам', ping: 18, pingRange: '18-28', load: 51, code: 'nl-ams-17', premium: true, pingLevel: 'low' },
                { flag: '🇬🇧', country: 'Великобритания', city: 'Лондон', ping: 22, pingRange: '22-32', load: 38, code: 'uk-lon-08', premium: true, pingLevel: 'low' },
                { flag: '🇫🇷', country: 'Франция', city: 'Париж', ping: 24, pingRange: '24-34', load: 29, code: 'fr-par-23', premium: true, pingLevel: 'low' },
                { flag: '🇯🇵', country: 'Япония', city: 'Токио', ping: 28, pingRange: '28-38', load: 52, code: 'jp-tyo-41', premium: true, pingLevel: 'low' },
                { flag: '🇸🇬', country: 'Сингапур', city: 'Сингапур', ping: 32, pingRange: '32-42', load: 47, code: 'sg-sin-08', premium: true, pingLevel: 'low' },
                
                // Бесплатные серверы - высокий пинг
                { flag: '🇷🇺', country: 'Россия', city: 'Москва', ping: 180, pingRange: '150-200', load: 95, code: 'ru-msk-free', premium: false, pingLevel: 'high' },
                { flag: '🇷🇺', country: 'Россия', city: 'СПб', ping: 210, pingRange: '180-230', load: 92, code: 'ru-spb-free', premium: false, pingLevel: 'high' },
                { flag: '🇺🇸', country: 'США', city: 'Нью-Йорк', ping: 250, pingRange: '220-280', load: 88, code: 'us-nyc-free', premium: false, pingLevel: 'high' },
                { flag: '🇨🇦', country: 'Канада', city: 'Торонто', ping: 270, pingRange: '240-300', load: 76, code: 'ca-tor-free', premium: false, pingLevel: 'high' },
                { flag: '🇧🇷', country: 'Бразилия', city: 'Сан-Паулу', ping: 320, pingRange: '280-350', load: 65, code: 'br-sao-free', premium: false, pingLevel: 'high' },
                { flag: '🇦🇺', country: 'Австралия', city: 'Сидней', ping: 380, pingRange: '350-420', load: 45, code: 'au-syd-free', premium: false, pingLevel: 'high' }
            ];
            
            const serverList = document.getElementById('serverList');
            serverList.innerHTML = '';
            
            servers.forEach(server => {
                const serverItem = document.createElement('div');
                serverItem.className = 'server-item';
                
                if (server.premium) {
                    serverItem.classList.add('premium-server');
                } else {
                    serverItem.classList.add('free-server');
                }
                
                serverItem.onclick = () => {
                    if (server.premium && !hasPremium) {
                        showToast('🔒 Серверы с низким пингом только для Premium', 'error');
                        buySubscription();
                    } else {
                        connectToServer(server.code);
                    }
                };
                
                let pingColor = '';
                let pingIndicator = '';
                
                if (server.pingLevel === 'low') {
                    pingColor = 'ping-low-text';
                    pingIndicator = '<span class="ping-indicator ping-low"></span>';
                } else if (server.pingLevel === 'high') {
                    pingColor = 'ping-high-text';
                    pingIndicator = '<span class="ping-indicator ping-high"></span>';
                }
                
                serverItem.innerHTML = `
                    <div class="server-info">
                        <span class="server-flag">${server.flag}</span>
                        <div class="server-details">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span class="server-name">${server.country}, ${server.city}</span>
                                ${server.premium ? '<span class="premium-badge">LOW PING</span>' : '<span class="free-badge">HIGH PING</span>'}
                            </div>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                ${pingIndicator}
                                <span class="server-ping ${pingColor}">${server.pingRange} мс</span>
                            </div>
                            <div class="load-bar">
                                <div class="load-fill" style="width: ${server.load}%;"></div>
                            </div>
                        </div>
                    </div>
                `;
                serverList.appendChild(serverItem);
            });
            
            document.getElementById('onlineUsers').textContent = Math.floor(2000 + Math.random() * 2000);
        }
        
        function switchTab(tabName) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');
            
            document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
            document.getElementById(tabName + 'Tab').classList.remove('hidden');
        }
        
        function connectToServer(serverCode) {
            const server = servers.find(s => s.code === serverCode);
            const isPremiumServer = server?.premium;
            
            if (isPremiumServer && !hasPremium) {
                showToast('🔒 Только Premium пользователи могут подключаться к серверам с низким пингом', 'error');
                buySubscription();
                return;
            }
            
            const pingType = isPremiumServer ? 'низким' : 'высоким';
            const emoji = isPremiumServer ? '⚡' : '🐢';
            showToast(`${emoji} Подключаемся к серверу с ${pingType} пингом...`, isPremiumServer ? 'premium' : 'free');
            
            tg.sendData(JSON.stringify({
                action: 'connect',
                server: serverCode,
                premium: isPremiumServer
            }));
            
            setTimeout(() => {
                showToast(`✅ Подключено к серверу с ${pingType} пингом`, isPremiumServer ? 'premium' : 'free');
            }, 2000);
        }
        
        function startSpeedTest() {
            const btn = document.getElementById('speedTestBtn');
            btn.disabled = true;
            btn.textContent = '⏳ Тестирование...';
            
            const speedDisplay = document.getElementById('speedDisplay');
            const speedMeter = document.getElementById('speedMeter');
            const pingDisplay = document.getElementById('pingDisplay');
            const lossDisplay = document.getElementById('lossDisplay');
            
            let progress = 0;
            if (speedTestInterval) clearInterval(speedTestInterval);
            
            speedTestInterval = setInterval(() => {
                progress += Math.random() * 10;
                if (progress >= 100) {
                    progress = 100;
                    clearInterval(speedTestInterval);
                    
                    let finalSpeed, finalPing, finalLoss;
                    
                    if (hasPremium) {
                        finalSpeed = (Math.random() * 280 + 120).toFixed(1);
                        finalPing = Math.floor(Math.random() * 20 + 10);
                        finalLoss = (Math.random() * 0.5).toFixed(1);
                    } else {
                        finalSpeed = (Math.random() * 20 + 5).toFixed(1);
                        finalPing = Math.floor(Math.random() * 150 + 100);
                        finalLoss = (Math.random() * 8 + 2).toFixed(1);
                    }
                    
                    speedDisplay.textContent = finalSpeed;
                    speedMeter.style.width = '100%';
                    pingDisplay.textContent = finalPing;
                    lossDisplay.textContent = finalLoss;
                    
                    btn.disabled = false;
                    btn.textContent = '▶ Начать тест';
                    
                    tg.sendData(JSON.stringify({
                        action: 'speed_test',
                        speed: finalSpeed,
                        ping: finalPing,
                        loss: finalLoss,
                        premium: hasPremium
                    }));
                    
                    const message = hasPremium ?
                        `📊 Premium: ${finalSpeed} Мбит/с, Пинг: ${finalPing} мс (низкий)` :
                        `📊 Бесплатно: ${finalSpeed} Мбит/с, Пинг: ${finalPing} мс (высокий)`;
                    
                    showToast(message, hasPremium ? 'premium' : 'free');
                } else {
                    if (hasPremium) {
                        speedDisplay.textContent = (progress * 4).toFixed(1);
                        pingDisplay.textContent = Math.floor(Math.random() * 20 + 15);
                    } else {
                        speedDisplay.textContent = (progress * 0.5).toFixed(1);
                        pingDisplay.textContent = Math.floor(Math.random() * 150 + 120);
                    }
                    speedMeter.style.width = progress + '%';
                }
            }, 100);
        }
        
        function buySubscription() {
            showToast('⏳ Перенаправление на оплату...', 'premium');
            
            tg.sendData(JSON.stringify({
                action: 'buy',
                price: 100
            }));
            
            setTimeout(() => {
                showToast('💎 После оплаты вы получите доступ к серверам с низким пингом', 'premium');
            }, 1000);
        }
        
        function getConfig() {
            showToast('⏳ Запрос конфигурации...');
            
            tg.sendData(JSON.stringify({
                action: 'get_config'
            }));
        }
        
        function support() {
            showToast('📞 Запрос в поддержку отправлен');
            
            tg.sendData(JSON.stringify({
                action: 'support'
            }));
        }
        
        setInterval(() => {
            document.getElementById('onlineUsers').textContent = Math.floor(2000 + Math.random() * 2000);
        }, 5000);
        
        loadServers();
        updateUIForPremium();
        
        tg.onEvent('mainButtonClicked', function() {
            buySubscription();
        });
        
        tg.MainButton.setText('Купить низкий пинг ⚡');
        tg.MainButton.onClick(buySubscription);
        tg.MainButton.show();
        
        setTimeout(() => {
            checkPremiumStatus();
        }, 500);
    </script>
</body>
</html>
